_pkg=libtalloc
_version=2.4.4
_uri=http://www.samba.org/ftp/talloc/talloc-${_version}.tar.gz
_dep="libtirpc"
_build_dep="compiletc coreutils python3.14 python3.14-dev libtirpc-dev"
_pkg_path=talloc-${_version}
_conf_cmd="setarch linux$arch ./configure"
_make_cmd="make"
_install_cmd="make install DESTDIR=" 
_pkgs='main{/usr}'
