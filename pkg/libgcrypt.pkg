_pkg=libgcrypt
_version=1.12.1
_uri=https://www.gnupg.org/ftp/gcrypt/libgcrypt/libgcrypt-${_version}.tar.bz2
_dep="libgpg-error"
_build_dep="libgpg-error"
_build_dep="compiletc coreutils libgpg-error"
_pkg_path=libgcrypt-${_version}
_conf_cmd="setarch linux$arch ./configure"
_make_cmd="make"
_install_cmd="make install DESTDIR=" 
_pkgs='main{/usr}'
