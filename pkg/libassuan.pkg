_pkg=libassuan
_version=3.0.2
_uri=https://www.gnupg.org/ftp/gcrypt/libassuan/libassuan-${_version}.tar.bz2
_dep="libgpg-error"
_build_dep="compiletc coreutils libgpg-error"
_pkg_path=libassuan-${_version}
_conf_cmd="setarch linux$arch ./configure"
_make_cmd="make"
_install_cmd="make install DESTDIR=" 
_pkgs='main{/usr}'
