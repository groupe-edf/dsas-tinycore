_pkg=libksba
_version=1.6.8
_uri=https://www.gnupg.org/ftp/gcrypt/libksba/libksba-${_version}.tar.bz2
_dep="libgpg-error"
_build_dep="compiletc coreutils libgpg-error"
_pkg_path=libksba-${_version}
_conf_cmd="setarch linux$arch ./configure"
_make_cmd="make"
_install_cmd="make install DESTDIR=" 
_pkgs='main{/usr}'
